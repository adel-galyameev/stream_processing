							"function randomString(len) {",
							"  const chars = 'abcdefghijklmnopqrstuvwxyz0123456789';",
							"  let result = '';",
							"  for (let i = 0; i < len; i++) result += chars[Math.floor(Math.random() * chars.length)];",
							"  return result;",
							"}",
							"",
							"const r1 = randomString(8);",
							"",
							"pm.collectionVariables.set('user_username', 'user_' + r1);",
							"pm.collectionVariables.set('user_email', 'user_' + r1 + '@test.com');"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				},
				{
					"listen": "test",
					"script": {
